# 复制为 .env 后按需修改
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:5173

REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# 32 字节随机字符串；生产请用 `openssl rand -hex 32` 重新生成
JWT_SECRET=dev-only-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_HOURS=24

LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_SECONDS=60

LANDMARK_AUTO_APPROVE=true
DEFAULT_GEO_KEY=geo:landmarks
